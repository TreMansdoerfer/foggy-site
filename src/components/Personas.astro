---
const personas = [
  {
    title: 'Telcos and call-center operators',
    text: 'Customer-care recordings transcribed in your data center, not Cape Town. Native Swahili and Kinyarwanda support.',
  },
  {
    title: 'Government agencies and ministries',
    text: "Document and audio processing without sending citizen data through Ireland or Virginia. Sovereign by architecture, not by promise.",
  },
  {
    title: 'Media, broadcasters, and content platforms',
    text: 'Index back catalogs, transcribe live broadcasts, and search across thousands of hours — in the languages your audience actually speaks.',
  },
];
---

<section id="personas" class="py-24 md:py-32 bg-white">
  <div class="mx-auto max-w-6xl px-6 md:px-8">
    <h2 class="font-bold tracking-tight text-foggy-ink text-center" style="font-size: clamp(28px, 4vw, 44px);">
      Who it's for.
    </h2>

    <p class="mx-auto mt-4 max-w-2xl text-center text-[20px] text-foggy-ink-light">
      If your business depends on AI working in a place AWS doesn't reach, we should talk.
    </p>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      {personas.map((p) => (
        <div class="rounded-xl border border-slate-200 bg-white p-8">
          <h3 class="text-[20px] font-bold text-foggy-ink">{p.title}</h3>
          <p class="mt-3 text-[17px] leading-[1.6] text-foggy-ink-light">{p.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
