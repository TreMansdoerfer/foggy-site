---
const personas = [
  { title: 'Banks and call-center operators', body: "A 1,000-agent call center generates 3 million minutes of audio a month. On AWS that's $72,000. On Foggy it's $36,000. Same Whisper models, in your building, with full Kinyarwanda support." },
  { title: 'Government agencies and ministries', body: 'Document processing, multilingual search, and audio transcription without sending citizen data through Ireland or Virginia. Compliant with regional data protection law by architecture, not by promise.' },
  { title: 'Media, broadcasters, and content platforms', body: 'Index back catalogs, transcribe live broadcasts, search across thousands of hours of audio — in the languages your audience actually speaks.' },
];
---

<section id="personas" class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6 md:px-8">
    <h2 class="text-center font-bold tracking-tight text-white" style="font-size: clamp(28px, 4vw, 44px);">
      Who it's for.
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-[18px] text-foggy-text-muted">
      If your business depends on AI working in a place AWS doesn't reach.
    </p>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      {personas.map((p) => (
        <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-8">
          <h3 class="text-[20px] font-bold text-white mb-3">{p.title}</h3>
          <p class="text-[16px] leading-[1.5] text-foggy-text">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
