---
const personas = [
  {
    title: 'Banks and call-center operators',
    text: "A 1,000-agent call center generates 3 million minutes of audio a month. On AWS that's $72,000. On Foggy it's $36,000. Same Whisper models, in your building, with full Kinyarwanda support. Around 30 large banks across Kenya, Rwanda, and Tanzania alone fit this profile.",
  },
  {
    title: 'Government agencies and ministries',
    text: 'Document processing, multilingual search, and audio transcription without sending citizen data through Ireland or Virginia. Compliant with Kenya DPA 2019 and Rwanda DPL by architecture, not by promise. MINICT Rwanda is in active conversations.',
  },
  {
    title: 'Media, broadcasters, and content platforms',
    text: 'Index back catalogs, transcribe live broadcasts, search across thousands of hours of audio — in Kinyarwanda, Swahili, and English. Major Kenyan media companies are part of our pilot pipeline.',
  },
];
---

<section id="personas" class="py-24 md:py-32 bg-white">
  <div class="mx-auto max-w-6xl px-6 md:px-8">
    <h2 class="font-bold tracking-tight text-foggy-ink text-center" style="font-size: clamp(28px, 4vw, 44px);">
      Who it's for.
    </h2>

    <p class="mx-auto mt-4 max-w-2xl text-center text-[20px] text-foggy-ink-light">
      If your business depends on AI working in a place AWS doesn't reach, we should talk.
    </p>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      {personas.map((p) => (
        <div class="rounded-xl border border-slate-200 bg-white p-8">
          <h3 class="text-[20px] font-bold text-foggy-ink">{p.title}</h3>
          <p class="mt-3 text-[17px] leading-[1.6] text-foggy-ink-light">{p.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
