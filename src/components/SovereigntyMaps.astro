---
// TODO: Replace world map placeholder SVGs with full geographic maps.
// Option A: Hand-author SVG paths for affected countries.
// Option B: Screenshot platform's Data Sovereignty maps as high-res images.
---

<section id="sovereignty" class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6 md:px-8">
    <h2 class="text-center font-bold tracking-tight text-white" style="font-size: clamp(28px, 4vw, 44px);">
      Where your data ends up.
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-[18px] text-foggy-text-muted">
      Same workload, two different outcomes.
    </p>

    <!-- Dual map cards -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Without Foggy -->
      <div class="rounded-xl border border-slate-800 overflow-hidden bg-slate-950">
        <div class="px-5 py-3 border-b border-slate-800">
          <span class="text-[14px] font-bold text-foggy-amber">Without Foggy — Cloud AI</span>
        </div>
        <div class="relative aspect-video bg-amber-950/30 flex items-center justify-center">
          <!-- Placeholder SVG — dashed amber lines from East Africa to AWS regions -->
          <svg viewBox="0 0 400 200" class="w-full h-full opacity-60" aria-label="Data routing from East Africa to cloud regions">
            <!-- Source cities -->
            <circle cx="220" cy="105" r="3" fill="#fb923c"/> <!-- Nairobi -->
            <circle cx="215" cy="90" r="3" fill="#fb923c"/>  <!-- Kigali -->
            <circle cx="225" cy="80" r="3" fill="#fb923c"/>  <!-- Addis -->
            <circle cx="190" cy="100" r="3" fill="#fb923c"/> <!-- Yaoundé -->
            <circle cx="310" cy="50" r="3" fill="#fb923c"/>  <!-- Almaty -->
            <!-- Target regions -->
            <circle cx="80" cy="60" r="5" fill="none" stroke="#fb923c" stroke-width="1.5"/>  <!-- Virginia -->
            <circle cx="160" cy="45" r="5" fill="none" stroke="#fb923c" stroke-width="1.5"/> <!-- Ireland -->
            <circle cx="200" cy="155" r="5" fill="none" stroke="#fb923c" stroke-width="1.5"/> <!-- Cape Town -->
            <circle cx="270" cy="65" r="5" fill="none" stroke="#fb923c" stroke-width="1.5"/>  <!-- Bahrain -->
            <!-- Routing lines -->
            <line x1="220" y1="105" x2="200" y2="155" stroke="#fb923c" stroke-width="1" stroke-dasharray="4 3" opacity="0.7"/>
            <line x1="220" y1="105" x2="160" y2="45" stroke="#fb923c" stroke-width="1" stroke-dasharray="4 3" opacity="0.7"/>
            <line x1="215" y1="90" x2="160" y2="45" stroke="#fb923c" stroke-width="1" stroke-dasharray="4 3" opacity="0.7"/>
            <line x1="225" y1="80" x2="270" y2="65" stroke="#fb923c" stroke-width="1" stroke-dasharray="4 3" opacity="0.7"/>
            <line x1="190" y1="100" x2="160" y2="45" stroke="#fb923c" stroke-width="1" stroke-dasharray="4 3" opacity="0.7"/>
            <line x1="310" y1="50" x2="270" y2="65" stroke="#fb923c" stroke-width="1" stroke-dasharray="4 3" opacity="0.7"/>
            <line x1="160" y1="45" x2="80" y2="60" stroke="#fb923c" stroke-width="1" stroke-dasharray="4 3" opacity="0.5"/>
            <!-- Labels -->
            <text x="75" y="50" fill="#94a3b8" font-size="8" text-anchor="middle">Virginia</text>
            <text x="160" y="37" fill="#94a3b8" font-size="8" text-anchor="middle">Ireland</text>
            <text x="200" y="170" fill="#94a3b8" font-size="8" text-anchor="middle">Cape Town</text>
            <text x="270" y="57" fill="#94a3b8" font-size="8" text-anchor="middle">Bahrain</text>
          </svg>
        </div>
        <div class="px-5 py-3 border-t border-slate-800">
          <p class="text-[14px] text-amber-400">Data travels to US, Europe, Cape Town, or Bahrain for processing.</p>
        </div>
      </div>

      <!-- With Foggy -->
      <div class="rounded-xl border border-slate-800 overflow-hidden bg-slate-950">
        <div class="px-5 py-3 border-b border-slate-800">
          <span class="text-[14px] font-bold text-teal-400">With Foggy — Local AI</span>
        </div>
        <div class="relative aspect-video bg-teal-950/30 flex items-center justify-center">
          <!-- Placeholder SVG — glowing local dots, no outbound lines -->
          <svg viewBox="0 0 400 200" class="w-full h-full opacity-70" aria-label="Data stays local in each country">
            <!-- Local processing dots with glow -->
            <circle cx="220" cy="105" r="6" fill="#14b8a6" opacity="0.3"/>
            <circle cx="220" cy="105" r="3" fill="#14b8a6"/>
            <circle cx="215" cy="90" r="6" fill="#14b8a6" opacity="0.3"/>
            <circle cx="215" cy="90" r="3" fill="#14b8a6"/>
            <circle cx="225" cy="80" r="6" fill="#14b8a6" opacity="0.3"/>
            <circle cx="225" cy="80" r="3" fill="#14b8a6"/>
            <circle cx="190" cy="100" r="6" fill="#14b8a6" opacity="0.3"/>
            <circle cx="190" cy="100" r="3" fill="#14b8a6"/>
            <circle cx="310" cy="50" r="6" fill="#14b8a6" opacity="0.3"/>
            <circle cx="310" cy="50" r="3" fill="#14b8a6"/>
            <!-- Labels -->
            <text x="220" y="120" fill="#94a3b8" font-size="8" text-anchor="middle">Nairobi</text>
            <text x="215" y="82" fill="#94a3b8" font-size="8" text-anchor="end">Kigali</text>
            <text x="225" y="72" fill="#94a3b8" font-size="8" text-anchor="start">Addis</text>
            <text x="190" y="112" fill="#94a3b8" font-size="8" text-anchor="middle">Yaoundé</text>
            <text x="310" y="42" fill="#94a3b8" font-size="8" text-anchor="middle">Almaty</text>
          </svg>
        </div>
        <div class="px-5 py-3 border-t border-slate-800">
          <p class="text-[14px] text-teal-400">Processing happens inside national borders. No data egress.</p>
        </div>
      </div>
    </div>

    <!-- Stat strip -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-0 md:divide-x md:divide-slate-800 text-center">
      <div class="py-4">
        <div class="text-[28px] font-bold text-white">Local</div>
        <div class="mt-1 text-[13px] font-bold tracking-widest uppercase text-foggy-text-faint">Data Residency</div>
      </div>
      <div class="py-4">
        <div class="text-[28px] font-bold"><span class="text-white">&lt;5ms</span> <span class="text-foggy-text-muted text-[18px]">vs 60–150ms</span></div>
        <div class="mt-1 text-[13px] font-bold tracking-widest uppercase text-foggy-text-faint">Latency</div>
      </div>
      <div class="py-4">
        <div class="text-[28px] font-bold text-white">Compliant</div>
        <div class="mt-1 text-[13px] font-bold tracking-widest uppercase text-foggy-text-faint">Kenya DPA · Rwanda DPL · Ethiopia DPP</div>
      </div>
    </div>
  </div>
</section>
