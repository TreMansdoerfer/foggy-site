---
import WorldMap from './maps/WorldMap.astro';

const customerIds = ['404', '646', '231', '120', '398'];

const customerCities: { name: string; coords: [number, number] }[] = [
  { name: 'Nairobi', coords: [36.8219, -1.2921] },
  { name: 'Kigali', coords: [30.0588, -1.9536] },
  { name: 'Addis Ababa', coords: [38.7578, 9.0292] },
  { name: 'Yaoundé', coords: [11.5021, 3.8480] },
  { name: 'Astana', coords: [71.4491, 51.1694] },
];

const awsRegions: { name: string; coords: [number, number] }[] = [
  { name: 'Virginia', coords: [-77.4360, 38.9469] },
  { name: 'Ireland', coords: [-6.2603, 53.3498] },
  { name: 'Cape Town', coords: [18.4241, -33.9249] },
  { name: 'Bahrain', coords: [50.5577, 26.0667] },
];
---

<section id="sovereignty" class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6 md:px-8">
    <h2 class="text-center font-bold tracking-tight text-white" style="font-size: clamp(28px, 4vw, 44px);">
      Where your data ends up.
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-[18px] text-foggy-text-muted">
      Same workload, two different outcomes.
    </p>

    <!-- Dual map cards -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Without Foggy -->
      <div>
        <div class="rounded-xl border border-slate-800 bg-slate-950 overflow-hidden">
          <div class="px-5 py-3 border-b border-slate-800">
            <span class="text-[14px] font-bold text-foggy-amber">Without Foggy — Cloud AI</span>
          </div>
          <div class="aspect-video p-3">
            <WorldMap
              mode="without"
              highlightCountryIds={customerIds}
              customerCities={customerCities}
              awsRegions={awsRegions}
            />
          </div>
        </div>
        <p class="text-amber-400 text-sm mt-3">Data travels to US, Europe, Cape Town, or Bahrain for processing.</p>
      </div>

      <!-- With Foggy -->
      <div>
        <div class="rounded-xl border border-slate-800 bg-emerald-950/30 overflow-hidden">
          <div class="px-5 py-3 border-b border-slate-800">
            <span class="text-[14px] font-bold text-emerald-400">With Foggy — Local AI</span>
          </div>
          <div class="aspect-video p-3">
            <WorldMap
              mode="with"
              highlightCountryIds={customerIds}
              customerCities={customerCities}
            />
          </div>
        </div>
        <p class="text-emerald-400 text-sm mt-3">Processing happens inside national borders. No data egress.</p>
      </div>
    </div>

    <!-- Stat strip -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-0 md:divide-x md:divide-slate-800 text-center">
      <div class="py-4">
        <div class="text-[28px] font-bold text-white">Local</div>
        <div class="mt-1 text-[13px] font-bold tracking-widest uppercase text-foggy-text-faint">Data Residency</div>
      </div>
      <div class="py-4">
        <div class="text-[28px] font-bold"><span class="text-white">&lt;5ms</span> <span class="text-foggy-text-muted text-[18px]">vs 60–150ms</span></div>
        <div class="mt-1 text-[13px] font-bold tracking-widest uppercase text-foggy-text-faint">Latency</div>
      </div>
      <div class="py-4">
        <div class="text-[28px] font-bold text-white">Compliant</div>
        <div class="mt-1 text-[13px] font-bold tracking-widest uppercase text-foggy-text-faint">Kenya DPA · Rwanda DPL · Ethiopia DPP</div>
      </div>
    </div>
  </div>
</section>
