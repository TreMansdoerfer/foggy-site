---
// Sticky nav — 5 links, transparent to white on scroll
---

<header id="site-nav" class="sticky top-0 z-50 transition-all duration-200 border-b border-transparent bg-transparent">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6 md:px-8">
    <a href="/" class="text-foggy-teal text-[22px] font-bold leading-none">Foggy</a>

    <div class="hidden md:flex items-center gap-6">
      <a href="#problem" class="text-[15px] text-foggy-text-muted-dark hover:text-white transition-colors nav-link">Why Foggy</a>
      <a href="#how" class="text-[15px] text-foggy-text-muted-dark hover:text-white transition-colors nav-link">How it works</a>
      <a href="#sovereignty" class="text-[15px] text-foggy-text-muted-dark hover:text-white transition-colors nav-link">Sovereignty</a>
      <a href="#compare" class="text-[15px] text-foggy-text-muted-dark hover:text-white transition-colors nav-link">Compare</a>
      <a href="#economics" class="text-[15px] text-foggy-text-muted-dark hover:text-white transition-colors nav-link">Economics</a>
    </div>

    <a href="#cta" class="rounded-lg bg-foggy-teal px-5 py-2.5 text-[14px] font-bold text-white hover:bg-foggy-teal-dark transition-colors">
      Request a pilot
    </a>
  </nav>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const links = nav?.querySelectorAll('.nav-link');
  if (nav) {
    const update = () => {
      const scrolled = window.scrollY > 100;
      if (scrolled) {
        nav.classList.add('bg-white', 'border-slate-200', 'shadow-sm');
        nav.classList.remove('bg-transparent', 'border-transparent');
        links?.forEach(l => { l.classList.remove('text-foggy-text-muted-dark', 'hover:text-white'); l.classList.add('text-foggy-ink-light', 'hover:text-foggy-ink'); });
      } else {
        nav.classList.remove('bg-white', 'border-slate-200', 'shadow-sm');
        nav.classList.add('bg-transparent', 'border-transparent');
        links?.forEach(l => { l.classList.add('text-foggy-text-muted-dark', 'hover:text-white'); l.classList.remove('text-foggy-ink-light', 'hover:text-foggy-ink'); });
      }
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
