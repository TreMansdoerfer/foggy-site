---
// CTA — dark background, matching hero
---

<section id="cta" class="hero-gradient py-32">
  <div class="mx-auto max-w-xl px-6 md:px-8 text-center">
    <h2 class="font-bold tracking-tight text-white" style="font-size: clamp(28px, 4vw, 44px);">
      Talk to us.
    </h2>
    <p class="mt-4 text-[17px] text-foggy-text-on-dark leading-relaxed">
      Pilot programs are starting now. If you run an institution in East Africa with idle compute and AI workloads — bank, ministry, university, broadcaster, telco — we'd like to hear from you. Same goes for investors.
    </p>

    <form id="cta-form" action="https://formspree.io/f/REPLACE_WITH_FORMSPREE_ID" method="POST" class="mt-10 flex flex-col gap-4 text-left">
      <input type="text" name="name" placeholder="Name" required class="w-full rounded-lg bg-slate-900/50 border border-slate-700 px-4 py-3 text-[16px] text-white placeholder:text-foggy-text-muted-dark focus:outline-none focus:ring-2 focus:ring-foggy-teal focus:border-foggy-teal" />
      <input type="email" name="email" placeholder="Work email" required class="w-full rounded-lg bg-slate-900/50 border border-slate-700 px-4 py-3 text-[16px] text-white placeholder:text-foggy-text-muted-dark focus:outline-none focus:ring-2 focus:ring-foggy-teal focus:border-foggy-teal" />
      <input type="text" name="organization" placeholder="Organization" required class="w-full rounded-lg bg-slate-900/50 border border-slate-700 px-4 py-3 text-[16px] text-white placeholder:text-foggy-text-muted-dark focus:outline-none focus:ring-2 focus:ring-foggy-teal focus:border-foggy-teal" />
      <textarea name="message" rows="4" placeholder="What are you trying to do?" required class="w-full rounded-lg bg-slate-900/50 border border-slate-700 px-4 py-3 text-[16px] text-white placeholder:text-foggy-text-muted-dark focus:outline-none focus:ring-2 focus:ring-foggy-teal focus:border-foggy-teal resize-y"></textarea>
      <button type="submit" class="w-full rounded-lg bg-foggy-teal px-5 py-3 font-bold text-white hover:bg-foggy-teal-dark transition-colors">
        Send
      </button>
    </form>

    <div id="cta-success" class="mt-10 hidden">
      <p class="text-[20px] font-bold text-white">Got it. We'll reply within 24 hours.</p>
      <p class="mt-3 text-[17px] text-foggy-text-on-dark">
        Or grab time directly:
        <a href="https://cal.com/tremansdoerfer" class="text-foggy-teal hover:underline" target="_blank" rel="noopener">Book a 30-minute intro &rarr;</a>
      </p>
    </div>

    <p class="mt-8 text-[14px] text-foggy-text-muted-dark">
      Or email <a href="mailto:tre@foggy.ai" class="text-foggy-teal hover:underline">tre@foggy.ai</a> directly. We read everything.
    </p>
  </div>
</section>

<script>
  const form = document.getElementById('cta-form') as HTMLFormElement | null;
  const success = document.getElementById('cta-success');
  if (form && success) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      try {
        const res = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } });
        if (res.ok) { form.style.display = 'none'; success.classList.remove('hidden'); }
      } catch { form.submit(); }
    });
  }
</script>
