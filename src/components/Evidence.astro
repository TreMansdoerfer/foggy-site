---
import LiveDemoEmbed from './LiveDemoEmbed.astro';

const stats = [
  {
    number: '60–80%',
    label: 'cheaper than AWS on real workloads',
    caption: 'Transcription at $0.012/min vs $0.024 on AWS Transcribe. Classification at $0.000023/query vs $0.000034 on AWS.',
  },
  {
    number: '0',
    label: 'cross-border data transfers',
    caption: 'Audio recorded in Nairobi is transcribed in Nairobi. Sovereign by architecture, not by promise.',
  },
  {
    number: '3 languages, more coming',
    label: 'Kinyarwanda, Swahili, English',
    caption: 'Native fine-tuned models (Whisper-Small-Kinyarwanda by mbazaNLP). Open-source models for more African languages emerge quarterly.',
  },
];
---

<section id="evidence" class="py-24 md:py-32 bg-foggy-bg">
  <div class="mx-auto max-w-6xl px-6 md:px-8">
    <h2 class="font-bold tracking-tight text-foggy-ink text-center" style="font-size: clamp(28px, 4vw, 44px);">
      What it actually does.
    </h2>

    <!-- Stats row -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      {stats.map((s) => (
        <div class="rounded-xl border border-slate-200 bg-white p-8">
          <div class="text-[36px] font-bold text-foggy-ink leading-tight">{s.number}</div>
          <div class="mt-2 text-[17px] text-foggy-ink">{s.label}</div>
          <div class="mt-2 text-[14px] text-foggy-ink-light">{s.caption}</div>
        </div>
      ))}
    </div>

    <!-- Narrative paragraph -->
    <p class="mx-auto mt-12 max-w-2xl text-center text-[17px] leading-[1.6] text-foggy-ink-light">
      Microsoft's AI Economy Institute reported in January 2026 that DeepSeek usage in Africa runs 2-4× higher than any other region — direct evidence that emerging-market customers will route around hyperscalers when something fits their constraints. Foggy is the platform that finally fits.
    </p>

    <!-- Demo embed placeholder -->
    <LiveDemoEmbed />
  </div>
</section>
