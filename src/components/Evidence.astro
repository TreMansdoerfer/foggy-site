---
import LiveDemoEmbed from './LiveDemoEmbed.astro';

const stats = [
  {
    number: '60–97%',
    label: 'cheaper than AWS Transcribe',
    caption: 'Measured against eu-west-1 pricing on real workloads.',
  },
  {
    number: '<5ms',
    label: 'latency on-LAN',
    caption: 'vs ~100ms over the PEACE cable to Marseille.',
  },
  {
    number: '3 languages',
    label: 'Swahili, Kinyarwanda, English',
    caption: 'With native fine-tuned models (Whisper-Small-Kinyarwanda by mbazaNLP).',
  },
];
---

<section id="evidence" class="py-24 md:py-32 bg-foggy-bg">
  <div class="mx-auto max-w-6xl px-6 md:px-8">
    <h2 class="font-bold tracking-tight text-foggy-ink text-center" style="font-size: clamp(28px, 4vw, 44px);">
      What it actually does.
    </h2>

    <!-- Stats row -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      {stats.map((s) => (
        <div class="rounded-xl border border-slate-200 bg-white p-8">
          <div class="text-[36px] font-bold text-foggy-ink leading-tight">{s.number}</div>
          <div class="mt-2 text-[17px] text-foggy-ink">{s.label}</div>
          <div class="mt-2 text-[14px] text-foggy-ink-light">{s.caption}</div>
        </div>
      ))}
    </div>

    <!-- Narrative paragraph -->
    <p class="mx-auto mt-12 max-w-2xl text-center text-[17px] leading-[1.6] text-foggy-ink-light">
      Audio recorded in Nairobi gets transcribed in Nairobi, on a laptop in your office, in under a minute. Every result we show below was generated by the live platform.
    </p>

    <!-- Demo embed placeholder -->
    <LiveDemoEmbed />
  </div>
</section>
